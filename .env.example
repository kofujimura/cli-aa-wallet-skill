# ---------------------------------------------------------------------------
# cli-aa-wallet-skill — copy this file to .env.local and fill in the values.
# .env.local is git-ignored. NEVER commit real keys.
# ---------------------------------------------------------------------------

# --- Network / RPC -----------------------------------------------------------
# Sepolia RPC endpoint. Alchemy free tier works well (you already use Alchemy).
# e.g. https://eth-sepolia.g.alchemy.com/v2/<YOUR_ALCHEMY_KEY>
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# --- Bundler + Paymaster (Pimlico) ------------------------------------------
# Get a free key at https://dashboard.pimlico.io . Sepolia bundler + verifying
# paymaster (sponsored gas) are free on testnet, so sends are gasless.
PIMLICO_API_KEY=

# ---------------------------------------------------------------------------
# SIGNER — choose ONE of the two modes below.
# ---------------------------------------------------------------------------

# Mode A) Web3Auth + Google login (the real goal; non-custodial, no key on disk)
# Create a project at https://dashboard.web3auth.io , network = Sapphire Devnet.
# Add a *custom* auth connection that validates Google id_tokens, then put its
# Auth Connection ID here. See README "Web3Auth setup".
WEB3AUTH_CLIENT_ID=
WEB3AUTH_AUTH_CONNECTION_ID=
# Key network the connection lives on. Must match the dashboard. Default below.
# Use sapphire_mainnet only if your dashboard project is on mainnet.
WEB3AUTH_NETWORK=sapphire_devnet

# Google OAuth client (type: Desktop app / Installed) used by `login`.
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Mode B) Local private key — quick testing only, skips Web3Auth entirely.
# If WEB3AUTH_CLIENT_ID is empty, the CLI falls back to this key.
# Generate a throwaway one with: openssl rand -hex 32  (prefix with 0x)
PRIVATE_KEY=
